{% include "partials/header.njk" %}

<article class="product-page pt-large pt-md-xlarge pb-medium">
  <div class="container">
    <div class="bg-light-1 rounded-md p-3 p-md-5">
      <div class="p-md-3">

      <div class="product-main row g-md-5">
        <div class="col-md-6 product-gallery" data-product-gallery>
          <a
            href="{{ productImage | url }}"
            class="lightbox-trigger product-main-link"
            data-no-swup
            data-product-main-link
            data-lightbox-src="{{ productImage | url }}"
          >
            <img src="{{ productImage }}" alt="{{ title }}" class="main-image" data-product-main-image>
          </a>
          {% if galleryImages and galleryImages.length %}
            <div class="gallery-thumbs" aria-label="Miniatury zdjęć produktu">
              <button
                type="button"
                class="gallery-thumb is-active"
                data-product-thumb
                data-image-src="{{ productImage | url }}"
                data-image-alt="{{ title }}"
                aria-label="Pokaż zdjęcie 1"
              >
                {% productThumb productImage, title + " - 1" %}
              </button>
              {% for image in galleryImages %}
                <button
                  type="button"
                  class="gallery-thumb"
                  data-product-thumb
                  data-image-src="{{ image | url }}"
                  data-image-alt="{{ title }} - {{ loop.index + 1 }}"
                  aria-label="Pokaż zdjęcie {{ loop.index + 1 }}"
                >
                  {% productThumb image, title + " - " + (loop.index + 1) %}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <div class="col-md-6 product-info">
          {% include "partials/breadcrumbs.njk" %}

          <h1 class="h2 product-title">{{ title }}</h1>

<!--
          <div class="product-price h2">
            <span class="amount">{{ price }}</span>
            <span class="currency">PLN</span>
          </div>
-->

          <div class="product-status">
            <div class="product-short-description">
              {{ description }}
            </div>
            <p class="vin-notice">
               {{ vinNotice }}
            </p>
          </div>

          <div class="actions">
            <a href="https://ore4x4.pl/pl/428-zabudowy-jusn" target="_blank" title="PrzejdLs do sklepu" class="button-anim btn-write magnetic mt-2 fade-in" data-strength="40">
              <div class="button-anim-text">
                <span>Przejdź do sklepu</span>
                <span>Przejdź do sklepu</span>
              </div>
              <div class="button-anim-icon">
                <svg height="18" viewBox="0 0 100 100" width="18" xmlns="http://www.w3.org/2000/svg" class="icon-link" style="enable-background:new 0 0 100 100" version="1.1" x="0px" xml:space="preserve" xmlns:xlink="http://www.w3.org/1999/xlink" y="0px">
                  <g>
                    <path d="M83.3,79.7c0,2-1.6,3.6-3.6,3.6H20.3c-2,0-3.6-1.6-3.6-3.6V20.3c0-2,1.6-3.6,3.6-3.6h23.4V9.5H20.3   c-6,0-10.8,4.8-10.8,10.8v59.4c0,6,4.8,10.8,10.8,10.8h59.4c6,0,10.8-4.8,10.8-10.8V56.3h-7.2V79.7z" fill="var(--color-accent-1)"></path>
                    <polygon fill="var(--color-accent-1)" points="56.3,9.5 56.3,16.7 78.2,16.7 49.9,45 55,50.1 83.3,21.8 83.3,43.7 90.5,43.7 90.5,9.5  "></polygon>
                  </g>
                </svg>
              </div>
            </a>

          </div>

          <div class="trust-badges">
            <p>Gwarancja bezpiecznych zakupów</p>
          </div>
        </div>
      </div>

      <div class="product-details rounded-md bg-md-light-2 py-md-3 px-md-5 mt-5">
        <section class="details-tab pb-small">
          <h2 class="section-title">Szczegóły produktu</h2>
          
          <div class="specs-grid bg-light-1 p-md-4">
            <div class="spec-item small">
              <strong>Materiał</strong> {{ material }}
            </div>

             <div class="spec-item small">
              <strong>Proces produkcji</strong> {{ process }}
            </div>

            {% if capacityStatic %}
            <div class="spec-item small">
              <strong>Nośność statyczna:</strong> 
              {{ capacityStatic }}
            </div>
            {% endif %}

            {% if capacityDynamic %}
            <div class="spec-item small">
              <strong>Nośność dynamiczna:</strong> 
             {{ capacityDynamic }}
            </div>
            {% endif %}

            {% if weight %}
            <div class="spec-item small">
              <strong>Waga:</strong> {{ weight }}
            </div>
            {% endif %}
          </div>

          <div class="description-content mt-5">
            {{ content | safe }}
          </div>
        </section>

      </div>

      {% if categories and categories.length and collections.productCategories and collections.productCategories[lang] and collections.productCategories[lang][categories[0]] %}
        {% set relatedProducts = collections.productCategories[lang][categories[0]] | sortByOrder %}
        {% set hasRelatedProducts = false %}
        {% for relatedProduct in relatedProducts if relatedProduct.url != page.url %}
          {% if loop.index <= 4 %}
            {% set hasRelatedProducts = true %}
          {% endif %}
        {% endfor %}

        {% if hasRelatedProducts %}
          <section class="related-products mt-5">
            <div class="related-products-header">
              <div>
                <p class="small uppercase color-accent-1 mb-0">Oferta</p>
                <h2 class="section-title mb-0">Zobacz również</h2>
              </div>
              <div class="related-products-nav d-none d-md-block">
                <button type="button" class="magnetic swiper-button-prev related-products-prev" data-strength="40" aria-label="Poprzedni produkt">
                  <svg viewBox="0 0 61 61" xmlns="http://www.w3.org/2000/svg" width="61" height="61" fill="none">
                    <circle cx="30.5" cy="30.5" r="30" stroke="var(--color-dark-2)"></circle>
                    <path d="M34.5 24L27 31.5L34.5 39" stroke-width="2" stroke="var(--color-dark-2)"></path>
                  </svg>
                </button>
                <button type="button" class="magnetic swiper-button-next related-products-next" data-strength="40" aria-label="Następny produkt">
                  <svg viewBox="0 0 61 61" xmlns="http://www.w3.org/2000/svg" width="61" height="61" fill="none">
                    <circle cx="30.5" cy="30.5" r="30" stroke="var(--color-dark-2)"></circle>
                    <path d="M28 24L35.5 31.5L28 39" stroke-width="2" stroke="var(--color-dark-2)"></path>
                  </svg>
                </button>
              </div>
            </div>

            <div class="swiper swiper-related">
              <div class="swiper-wrapper">
                {% for relatedProduct in relatedProducts if relatedProduct.url != page.url %}
                  {% if loop.index <= 4 %}
                    <div class="swiper-slide">
                      <a href="{{ relatedProduct.url | url }}" class="related-product-link">
                        <article class="product-card rounded-md">
                          {% productImage relatedProduct.data.productImage, relatedProduct.data.title %}
                          <div class="product-card-content p-4 bg-light-1">
                            <h3 class="h4 mt-0 line-clamp-3">{{ relatedProduct.data.title }}</h3>
                            <span class="color-accent-1 small">Zobacz więcej &rarr;</span>
                          </div>
                        </article>
                      </a>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>

            <div class="related-products-scrollbar-wrap">
              <div class="swiper-scrollbar related-products-scrollbar"></div>
            </div>
          </section>
        {% endif %}
      {% endif %}

      </div>
    </div>
  </div>
</article>

<div class="lightbox" id="lightbox" aria-hidden="true">
  <div class="lightbox-backdrop" data-lightbox-close></div>
  <div class="lightbox-content" role="dialog" aria-modal="true" aria-label="Zdjęcie produktu">
    <button type="button" class="lightbox-close" data-lightbox-close>X</button>
    <img src="" alt="" class="lightbox-image" id="lightbox-image">
    <div class="lightbox-nav" aria-label="Nawigacja galerii">
      <button type="button" class="lightbox-nav-btn" data-lightbox-prev aria-label="Poprzednie zdjęcie">Poprzednie</button>
      <button type="button" class="lightbox-nav-btn" data-lightbox-next aria-label="Następne zdjęcie">Kolejne</button>
    </div>
  </div>
</div>



{% include "partials/footer.njk" %}

