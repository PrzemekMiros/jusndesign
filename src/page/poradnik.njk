---
lang: pl
layout: layouts/base.njk
title: Poradnik
description: Artykuły i poradniki JUSN Design Europe o montażu, dopasowaniu i praktycznym użytkowaniu akcesoriów.
permalink: /poradnik/
---

<section class="pt-xlarge pb-large" data-scroll-section>
  <div class="container">
    <nav class="breadcrumbs uppercase small color-accent-1">
      <a href="/">Strona główna</a>
      <span>|</span>
      <span>{{ title }}</span>
    </nav>
    <h1 class="xl split-lines color-light-1 mt-3 mb-5">{{ title }}</h1>

    {% set articles = collections.articles | byLang(lang) %}
    {% if articles and articles.length %}
      <div class="row g-4">
        {% for article in articles %}
          <div class="col-md-6 col-lg-4">
            <a href="{{ article.url | url }}" class="guide-card-link">
              <article class="guide-card rounded-md">
                <div class="guide-card-media">
                  <img
                    src="{{ (article.data.thumbnail or article.data.articleImage or '/assets/img/opengraph.png') | url }}"
                    alt="{{ article.data.title or ('Artykuł ' + article.page.fileSlug) }}"
                  >
                </div>
                <div class="guide-card-content bg-light-1 p-4">
                  <p class="small uppercase color-accent-1 mb-2">
                    {{ (article.data.tags | join(', ')) if article.data.tags and article.data.tags.length else 'Poradnik' }}
                  </p>
                  <h2 class="h3 mt-0 mb-3">{{ article.data.title or ('Artykuł ' + article.page.fileSlug) }}</h2>
                  <p class="mb-3 line-clamp-3">
                    {{ article.data.description or 'Przeczytaj artykuł z poradami i informacjami praktycznymi.' }}
                  </p>
                  <span class="color-accent-1 small">Czytaj artykuł &rarr;</span>
                </div>
              </article>
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="bg-light-1 p-4 rounded-md">
        <p class="mb-0">Brak artykułów do wyświetlenia.</p>
      </div>
    {% endif %}
  </div>
</section>
